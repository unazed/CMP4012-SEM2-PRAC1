<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25.0.2"
    xmlns:fx="http://javafx.com/fxml/1" prefHeight="578.0" prefWidth="504.0"
    fx:controller="com.unazed.LibraryManagement.controller.RegisterController">
  <children>
    <VBox layoutX="111.0" layoutY="176.0"
        maxHeight="1.7976931348623157E308"
        maxWidth="1.7976931348623157E308" minHeight="200.0"
        minWidth="200.0" prefHeight="213.0" prefWidth="268.0"
        AnchorPane.bottomAnchor="162.0" AnchorPane.leftAnchor="111.0"
        AnchorPane.rightAnchor="64.0" AnchorPane.topAnchor="176.0">
      <children>
        <Label text="Register">
          <font>
            <Font size="24.0" />
          </font>
          <VBox.margin>
            <Insets bottom="30.0" />
          </VBox.margin>
        </Label>
        <HBox fillHeight="false" maxHeight="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            VBox.vgrow="ALWAYS">
          <children>
            <GridPane maxHeight="1.7976931348623157E308"
                maxWidth="1.7976931348623157E308"
                prefHeight="120.0" prefWidth="269.0"
                HBox.hgrow="ALWAYS">
              <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" maxWidth="118.0"
                    minWidth="10.0" prefWidth="113.0" />
                <ColumnConstraints hgrow="ALWAYS"
                    maxWidth="1.7976931348623157E308"
                    minWidth="10.0" prefWidth="156.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0"
                    vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0"
                    vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0"
                    vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0"
                    vgrow="SOMETIMES" />
              </rowConstraints>
              <children>
                <TextField fx:id="tfRegisterEmail"
                maxWidth="1.7976931348623157E308" GridPane.columnIndex="1"
                    GridPane.hgrow="ALWAYS" />
                <Label text="E-mail" />
                <Label text="Confirm password" GridPane.rowIndex="3" />
                <PasswordField fx:id="tfRegisterConfirmPassword"
                    GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <Label text="Password" GridPane.rowIndex="2" />
                <Label text="Username" GridPane.rowIndex="1" />
                <PasswordField fx:id="tfRegisterPassword"
                    GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <TextField fx:id="tfRegisterUsername"
                    GridPane.columnIndex="1" GridPane.rowIndex="1" />
              </children>
            </GridPane>
          </children>
        </HBox>
        <Button fx:id="btnRegister" mnemonicParsing="false" text="Register"
            onAction="#onRegisterClick">
          <VBox.margin>
            <Insets top="10.0" />
          </VBox.margin>
        </Button>
      </children>
    </VBox>
  </children>
</AnchorPane>