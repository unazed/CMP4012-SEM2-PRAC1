<VBox prefHeight="600.0" prefWidth="900.0"
    fx:controller="com.unazed.LibraryManagement.controller.MainController"
    xmlns="http://javafx.com/javafx/25.0.2" xmlns:fx="http://javafx.com/fxml/1">
  <children>
    <fx:include source="AuthMenu.fxml" fx:id="authMenu" />
    <SplitPane dividerPositions="0.25, 0.75" focusTraversable="true"
        prefHeight="-1.0" prefWidth="-1.0" VBox.vgrow="ALWAYS"
        fx:id="mainSplitPane">
      <items>
        <AnchorPane style="-fx-background-color: lightgrey;" />
        <StackPane fx:id="contentPane" />
        <AnchorPane style="-fx-background-color: lightgrey;" />
      </items>
         <cursor>
            <Cursor fx:constant="DEFAULT" />
         </cursor>
    </SplitPane>
    <fx:include source="StatusMenu.fxml" fx:id="statusMenu" />
  </children>
</VBox>
